{
  "name": "fastcode-backend",
  "version": "1.0.0",
  "description": "FastCode - 代码全流程生成平台后端",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "test": "node --test -r ts-node/register src/common/file.service.spec.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.4.7",
    "@langchain/openai": "^1.5.5",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/websockets": "^11.1.28",
    "@opencode-ai/sdk": "^1.17.20",
    "@prisma/client": "^5.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "langchain": "^1.5.3",
    "multer": "^2.2.0",
    "openai": "^4.28.0",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "prisma": "^5.8.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
